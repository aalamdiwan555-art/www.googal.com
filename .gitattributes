# Set default behavior to automatic text/binary detection.
* text=auto

# Force text files to use LF line endings on checkout
*.kt text eol=lf
*.java text eol=lf
*.xml text eol=lf
*.gradle text eol=lf
*.gradle.kts text eol=lf
*.properties text eol=lf
*.txt text eol=lf
*.md text eol=lf
*.json text eol=lf

# Explicitly mark binary files as binary to prevent corruption
*.jar binary
*.png binary
*.jpg binary
*.webp binary
*.gif binary
*.keystore binary
*.jks binary
*.so binary
